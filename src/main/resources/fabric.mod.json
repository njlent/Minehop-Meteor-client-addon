{
	"schemaVersion": 1,
	"id": "minehop-meteor",
	"version": "${version}",
	"name": "Minehop Meteor Addon",
	"description": "An all in one bhopping addon for Meteor Client!",
	"authors": [
		"Plaaasma",
		"lolrow",
		"Moriz",
		"njlent"
	],
	"contact": {
		"homepage": "https://github.com/njlent/minehop",
		"sources": "https://github.com/njlent/minehop",
		"issues": "https://github.com/njlent/minehop/issues"
	},
	"license": "SEE LICENSE",
	"icon": "assets/minehop/logo.png",
	"environment": "*",
	"entrypoints": {
		"meteor": [
			"net.nerdorg.minehop.MinehopAddon"
		]
	},
	"mixins": [
		"minehop.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${mc_version}",
		"java": ">=${jdk_version}",
		"meteor-client": "*",
		"fabric-api": "*"
	},
	"custom": {
		"meteor-client:color": "225,25,25",
		"modmenu": {
			"parent": {
				"id": "meteor-client"
			}
		}
	}
}
